[Unit]
Description=Spider KPI nightly telemetry anomaly detection
After=network-online.target
OnFailure=spider-kpi-job-failure@%n.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/spiderclawkpi/spider/apps/spider-kpi
EnvironmentFile=/opt/spiderclawkpi/spider/apps/spider-kpi/.env
ExecStart=/opt/spiderclawkpi/spider/apps/spider-kpi/.venv/bin/python /opt/spiderclawkpi/spider/apps/spider-kpi/scripts/detect_telemetry_anomalies.py
StandardOutput=append:/var/log/spider-kpi-telemetry-anomalies.log
StandardError=append:/var/log/spider-kpi-telemetry-anomalies.log
