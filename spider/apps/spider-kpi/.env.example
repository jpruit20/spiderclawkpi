# Core sidecar / OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
WORKSPACE_ROOT=/home/jpruit20/.openclaw/workspace/spider
TARGET_REPO=/home/jpruit20/.openclaw/workspace/spider
MAX_FILE_CHARS=12000
POLL_SECONDS=2
MAX_CONTEXT_FILES=6

# General app / server
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
TIMEZONE=America/New_York

# Shopify
SHOPIFY_STORE_URL=spider-grills.myshopify.com
# Option A: static admin token
SHOPIFY_ADMIN_ACCESS_TOKEN=your_shopify_admin_access_token_here
# Option B: 24-hour client-credentials token refresh
SHOPIFY_API_KEY=your_shopify_client_id_here
SHOPIFY_API_SECRET=your_shopify_client_secret_here
SHOPIFY_API_VERSION=2026-01

# Triple Whale
TRIPLE_WHALE_API_KEY=your_triple_whale_api_key_here
TRIPLE_WHALE_BASE_URL=https://api.triplewhale.com

# Freshdesk
FRESHDESK_DOMAIN=your_domain_here
FRESHDESK_API_KEY=your_freshdesk_api_key_here
FRESHDESK_API_BASE_URL=https://your_domain.freshdesk.com/api/v2

# Google Analytics 4
GA4_PROPERTY_ID=your_ga4_property_id_here
GA4_CLIENT_EMAIL=your_service_account_client_email_here
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GA4_PROJECT_ID=your_gcp_project_id_here
GA4_DATA_API_BASE_URL=https://analyticsdata.googleapis.com
GA4_ADMIN_API_BASE_URL=https://analyticsadmin.googleapis.com

# Microsoft Clarity
CLARITY_PROJECT_ID=your_clarity_project_id_here
CLARITY_API_TOKEN=your_clarity_api_token_here
CLARITY_BASE_URL=https://www.clarity.ms/export-data/api/v1/project-live-insights
# Optional explicit override if Microsoft changes the documented path
# CLARITY_ENDPOINT=https://www.clarity.ms/export-data/api/v1/project-live-insights

# Microsoft Dynamics / Business Central
DYNAMICS_TENANT_ID=your_azure_tenant_id_here
DYNAMICS_CLIENT_ID=your_azure_app_client_id_here
DYNAMICS_CLIENT_SECRET=your_azure_app_client_secret_here
DYNAMICS_ENVIRONMENT=Production
DYNAMICS_COMPANY_ID=your_company_id_here
DYNAMICS_BASE_URL=https://api.businesscentral.dynamics.com
DYNAMICS_API_VERSION=v2.0

# Microsoft Graph (optional if needed for supporting Microsoft data access)
MS_GRAPH_TENANT_ID=your_azure_tenant_id_here
MS_GRAPH_CLIENT_ID=your_graph_client_id_here
MS_GRAPH_CLIENT_SECRET=your_graph_client_secret_here
MS_GRAPH_BASE_URL=https://graph.microsoft.com

# Reddit listening
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here
REDDIT_USER_AGENT=SpiderKPIDashboard/1.0 by your_reddit_username
REDDIT_SUBREDDITS=bbq,pelletgrills,smoking,grilling,webergrills

# Discord listening (for owned / approved communities)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_discord_application_id_here
DISCORD_GUILD_IDS=comma_separated_guild_ids_here
DISCORD_CHANNEL_IDS=comma_separated_channel_ids_here

# Facebook / Meta public content ingestion
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_SYSTEM_USER_ACCESS_TOKEN=your_meta_system_user_access_token_here
META_GRAPH_API_VERSION=v23.0
META_GRAPH_BASE_URL=https://graph.facebook.com
FACEBOOK_PAGE_IDS=comma_separated_page_ids_here

# Google Search discovery / web search layer
SERPAPI_API_KEY=your_serpapi_api_key_here
GOOGLE_SEARCH_LOCALE=us
GOOGLE_SEARCH_LANGUAGE=en
GOOGLE_SEARCH_RESULTS_PER_QUERY=20
WEB_DISCOVERY_ENABLED=true

# Optional review platforms / customer review feeds
JUDGEME_PRIVATE_API_TOKEN=your_judge_me_token_here
SHOPIFY_PRODUCT_REVIEWS_ENABLED=true
TRUSTPILOT_API_KEY=your_trustpilot_api_key_here

# Optional ad platform data sources
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_dev_token_here
GOOGLE_ADS_CUSTOMER_ID=your_google_ads_customer_id_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_google_ads_manager_id_here
META_ADS_ACCOUNT_IDS=comma_separated_meta_ads_account_ids_here

# Optional data warehouse / cache
POSTGRES_URL=postgres://user:password@localhost:5432/spider_kpi
REDIS_URL=redis://localhost:6379

# External listening configuration
VOC_ENABLED=true
VOC_LOOKBACK_DAYS=30
VOC_MAX_ITEMS_PER_SOURCE=250
VOC_REFRESH_MINUTES=15
VOC_SENTIMENT_PROVIDER=openai
VOC_THEME_EXTRACTION_PROVIDER=openai
VOC_STORE_RAW_TEXT=true
VOC_DEDUP_WINDOW_HOURS=48
VOC_BRAND_KEYWORDS=spider grills,spidergrills,venom,huntsman
VOC_PRODUCT_KEYWORDS=venom,huntsman,thermometer,grill,kettle,temperature controller
VOC_COMPETITOR_KEYWORDS=weber,traeger,big green egg,kamado joe,recteq,blackstone

# Safety / compliance toggles
ENABLE_PLATFORM_COMPLIANCE_MODE=true
ENABLE_RATE_LIMIT_BACKOFF=true
ENABLE_ROBOTS_TXT_RESPECT=true
ENABLE_RAW_HTML_ARCHIVE=false
